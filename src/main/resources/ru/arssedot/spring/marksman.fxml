<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="ru.arssedot.spring.controller.GameController"
            stylesheets="@style.css"
            styleClass="root-pane">

    <center>
        <StackPane styleClass="canvas-wrapper">
            <Canvas fx:id="canvas" width="600" height="420" focusTraversable="true"/>
        </StackPane>
    </center>

    <right>
        <VBox styleClass="score-panel" spacing="6" alignment="TOP_CENTER" prefWidth="210">
            <padding>
                <Insets top="12" right="12" bottom="12" left="12"/>
            </padding>

            <Label text="МЕТКИЙ СТРЕЛОК" styleClass="panel-title"/>

            <Label text="Счёт игрока:" styleClass="stat-caption"/>
            <Label fx:id="scoreLabel" text="0" styleClass="stat-score"/>

            <Label text="Выстрелов:" styleClass="stat-caption"/>
            <Label fx:id="shotsLabel" text="0" styleClass="stat-shots"/>

            <Separator/>

            <Label text="● Ближняя цель: +1 очко" styleClass="info-near"/>
            <Label text="● Дальняя цель: +2 очка" styleClass="info-far"/>

            <Separator/>

            <HBox spacing="4" alignment="CENTER_LEFT">
                <Label text="Скорость стрелы:" styleClass="slider-caption"/>
                <Label fx:id="arrowSpeedLabel" text="5.0" styleClass="slider-val"/>
            </HBox>
            <Slider fx:id="arrowSpeedSlider" min="2" max="10" value="5" prefWidth="185"/>

            <HBox spacing="4" alignment="CENTER_LEFT">
                <Label text="Скорость мишеней:" styleClass="slider-caption"/>
                <Label fx:id="targetSpeedLabel" text="2.0" styleClass="slider-val"/>
            </HBox>
            <Slider fx:id="targetSpeedSlider" min="0.5" max="5" value="2" prefWidth="185"/>

            <Separator/>

            <Label text="W / S — прицеливание" styleClass="hint"/>
            <Label text="Пробел — выстрел" styleClass="hint"/>
        </VBox>
    </right>

    <bottom>
        <HBox styleClass="button-bar" spacing="12" alignment="CENTER">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <Button text="▶  Начало игры" onAction="#onStart" styleClass="btn-start"/>
            <Button text="■  Остановить"  onAction="#onStop"  styleClass="btn-stop"/>
            <Button fx:id="pauseButton" text="⏸  Пауза" onAction="#onPause" styleClass="btn-pause"/>
            <Button text="→  Выстрел" onAction="#onShoot" styleClass="btn-shoot"/>
        </HBox>
    </bottom>

</BorderPane>
